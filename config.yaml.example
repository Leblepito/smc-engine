# SMC Engine — Configuration Template
#
# Bu dosya repo'da template olarak commit'lenir. Gerçek `config.yaml`
# bu dosyayı kopyalayıp lokal / VPS-spesifik değerlerle doldurularak
# üretilir. `config.yaml` `.gitignore` içindedir — accidental commit yok.
#
# Kullanım:
#   cp config.yaml.example config.yaml
#   # config.yaml'i kendi bütçen / sembollerin / mainnet flagleriyle güncelle
#
# Pattern: .env / .env.example ile birebir simetrik.

# ============================================================
# Sub-proje #5 — Execution layer
# ============================================================
execution:
  enabled: false              # MASTER FLAG. Default kapalı. Smoke için aç.
  phase: "5A"                 # "5A" (walking skeleton) | "5B" (production v1)
  testnet: true               # true: Binance Futures Testnet, false: Mainnet
  live_enabled: false         # MainnetGuard layer 2. Mainnet için true
                              # (env SMC_ALLOW_LIVE=1 + bu = MAINNET)
  symbols: ["BTCUSDT"]        # 5A: tek sembol. 5B: ["BTCUSDT","ETHUSDT","SOLUSDT","AVAXUSDT","LINKUSDT"]

  # 5A sabit değerleri
  risk_per_trade_dollar: 2.0
  leverage: 10
  margin_mode: "isolated"
  order_timeout_minutes: 60

  # Binance Futures account position mode — HESABIN GERÇEK MODUNA EŞLE.
  # "ONE_WAY"  (default): tek pozisyon, positionSide=BOTH (gönderilmez)
  # "HEDGE"   (testnet default): LONG/SHORT ayrı, positionSide gerekli
  # Yanlış değer → Binance -4061 "Order's position side does not match user's setting".
  # Boot'ta gerçek hesap mode'u sorgulanır + mismatch warning loglanır.
  position_mode: "ONE_WAY"

  # Bug E (2026-05-19): LIMIT entry'nin anlık fill durumu → SL stop_price
  # market'in yanlış tarafına düşer → -2021 reject + atomic rollback (smoke
  # fonksiyonel değil). İki katman defense-in-depth:
  #
  # pre_place_mark_guard (B, primary): process_setup öncesi mark_price çek;
  #   LONG için mark < entry veya SHORT için mark > entry ise setup atlanır
  #   (SETUP_SKIPPED_PRICE_PASSED audit, order place YOK). Fetch fail
  #   fail-safe → order yine place edilir (downstream A yakalar).
  pre_place_mark_guard: true
  #
  # post_only (A, secondary): LIMIT entry GTX (Good Till Crossing, Binance
  # futures'ın LIMIT_MAKER muadili) TimeInForce ile gönderilir. Order mark
  # price'ın yanlış tarafındaysa Binance place ETMEZ (taker fill engellenir).
  # TP exit order'ları GTC kalır (TP fiyatına ulaşıldığında likidite yoksa
  # reject olmasın). Klasik GTC davranışı için false yap.
  post_only: true

  # İş 1 (2026-05-19): aynı anda açık+pending pozisyon üst sınırı —
  # PER-SYMBOL (per-tracker). run_live.py her sembol için ayrı OrderManager+
  # PositionTracker init eder, bu yüzden cap her sembol bağımsız uygulanır.
  # Cross-symbol global cap 5B scope'unda.
  # Cap'e ulaşılırsa SETUP_SKIPPED_MAX_CONCURRENT audit + skip.
  # <=0 → guard kapalı (sınırsız). 5A: tek-pozisyon ruhu (averaging gate
  # PENDING-inclusive extension).
  max_concurrent_positions: 1

  # ──────────────────────────────────────────────────────────────────────
  # 5A genişletme override (kullanıcı kararı — opsiyonel, smoke veri toplama):
  # Sub-proje #2 sinyal pipeline'ı BTCUSDT için sessiz 6+ saat olduğunda
  # multi-symbol smoke veri akışını hızlandırır. Spec §16.2 acceptance
  # kriterleri (10-12 trade) tek sembolde uzun sürebilir.
  #
  #   symbols: ["BTCUSDT", "ETHUSDT", "SOLUSDT"]
  #   max_concurrent_positions: 1   # PER SYMBOL — 3 sembol × 1 = en fazla 3 toplam
  #
  # !!! ÖNEMLİ — RİSK BÜTÇE UYARISI !!!
  # Cap PER-SYMBOL'dür: cap=N + S sembol → toplam max N×S pozisyon.
  # risk_per_trade_dollar=$2, cap=1, 3 sembol → max toplam risk = $6 = %6.
  # Eğer cap=3 koyarsan: 3×3 = 9 pozisyon = $18 = %18 ($100 bütçenin %18'i).
  # 5A acceptance için cap=1 + N sembol önerilir (her sembol için 1 pozisyon).
  # ──────────────────────────────────────────────────────────────────────

  # Kill switch — $100 bütçe default'u (kullanıcı kararı 2026-05-17).
  # $25 bütçe için: daily_loss_dollar=5.0, equity_minimum=15.0
  kill_switch:
    consecutive_losses: 3
    daily_loss_dollar: 10.0
    equity_minimum: 75.0

  # Polling intervals (genellikle değiştirilmez)
  fill_polling_seconds: 30
  reconcile_loop_seconds: 300

  # Paths (gitignored: logs/)
  audit_log_dir: "logs/trades"
  state_dir: "logs/state"

# ============================================================
# Sub-proje #2 — Signal pipeline (log-only fallback)
# ============================================================
live:
  symbols: ["BTCUSDT", "ETHUSDT", "SOLUSDT"]
  scheduler_buffer_seconds: 5
  log_dir: "./logs"

binance:
  testnet: false              # sub-proje #2 read path (kline). Execution path'i ayrı (execution.testnet).
  rate_limit_buffer: 0.8
