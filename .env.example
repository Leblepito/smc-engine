# Mainnet keys (sub-proje #2 read-only + #5 mainnet execution)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Testnet keys (sub-proje #5A testnet smoke için)
# Binance Futures Testnet: https://testnet.binancefuture.com/
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_API_SECRET=

# Sub-proje #5A mainnet 3 katman guard'ı:
#   1) bu env değişkeni = 1
#   2) config.execution.live_enabled = true
#   3) startup'ta 5sn delay + warning (otomatik)
# Default 0 = TESTNET zorlanır. Mainnet açmak için: 1 yap + config + restart.
SMC_ALLOW_LIVE=0
